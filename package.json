{
  "name": "tablens",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.tsx",
    "./engine": "./src/engine/index.ts",
    "./engine/*": "./src/engine/*",
    "./app/*": "./src/app/*",
    "./layout/*": "./src/layout/*",
    "./utils/*": "./src/utils/*",
    "./*": "./src/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run --watch index.ts",
    "tablens": "bun run index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.1",
    "@opentui/core": "^0.2.14",
    "@opentui/react": "^0.2.14",
    "react": "^19.2.3"
  }
}